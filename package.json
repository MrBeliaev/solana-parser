{
  "name": "solana-parser",
  "version": "0.0.1",
  "description": "Solana block parser pipeline (block-listener -> parser -> token-enricher/clickhouse-writer -> ClickHouse) with a GraphQL read API, built as a NestJS microservices monorepo.",
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/MrBeliaev/solana-parser.git"
  },
  "scripts": {
    "build": "npx tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "jest",
    "migrate": "ts-node scripts/migrate.ts",
    "dependency:check": "madge --circular --warning --ts-config=./tsconfig.json --extensions ts --exclude \"^(node_modules|dist|clickhouse-data)/\" apps libs",
    "prepare": "husky"
  },
  "dependencies": {
    "@apollo/server": "^5.5.1",
    "@clickhouse/client": "^1.23.0",
    "@coral-xyz/anchor": "^0.32.1",
    "@nestjs/apollo": "^13.4.2",
    "@nestjs/common": "^11.1.27",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.27",
    "@nestjs/graphql": "^13.4.2",
    "@nestjs/microservices": "^11.1.27",
    "@nestjs/platform-express": "^11.1.27",
    "@solana/web3.js": "^1.98.4",
    "borsh": "^2.0.0",
    "bs58": "^6.0.0",
    "dotenv": "^17.4.2",
    "graphql": "^17.0.1",
    "kafkajs": "^2.2.4",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.23",
    "@nestjs/testing": "^11.1.27",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/jest": "^30.0.0",
    "@types/madge": "^5.0.3",
    "@types/node": "^26.1.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.62.1",
    "eslint": "^10.6.0",
    "eslint-plugin-import-newlines": "^2.0.0",
    "eslint-plugin-import-x": "^4.17.1",
    "eslint-plugin-jest": "^29.15.4",
    "eslint-plugin-n": "^18.2.1",
    "eslint-plugin-promise": "^7.3.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "lint-staged": "^17.0.8",
    "madge": "^8.0.0",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typescript": "6.0.3"
  },
  "overrides": {
    "graphql": "^17.0.1",
    "typescript": "6.0.3",
    "uuid": "^11.1.1",
    "ws": "^8.21.0",
    "multer": "^2.2.0"
  },
  "lint-staged": {
    "*.ts": "eslint --fix"
  }
}
