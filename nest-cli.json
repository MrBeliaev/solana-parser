{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "apps/block-listener/src",
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": false,
    "tsConfigPath": "apps/block-listener/tsconfig.app.json"
  },
  "monorepo": true,
  "root": "apps/block-listener",
  "projects": {
    "block-listener": {
      "type": "application",
      "root": "apps/block-listener",
      "entryFile": "main",
      "sourceRoot": "apps/block-listener/src",
      "compilerOptions": {
        "tsConfigPath": "apps/block-listener/tsconfig.app.json"
      }
    },
    "parser": {
      "type": "application",
      "root": "apps/parser",
      "entryFile": "main",
      "sourceRoot": "apps/parser/src",
      "compilerOptions": {
        "tsConfigPath": "apps/parser/tsconfig.app.json"
      }
    },
    "token-enricher": {
      "type": "application",
      "root": "apps/token-enricher",
      "entryFile": "main",
      "sourceRoot": "apps/token-enricher/src",
      "compilerOptions": {
        "tsConfigPath": "apps/token-enricher/tsconfig.app.json"
      }
    },
    "clickhouse-writer": {
      "type": "application",
      "root": "apps/clickhouse-writer",
      "entryFile": "main",
      "sourceRoot": "apps/clickhouse-writer/src",
      "compilerOptions": {
        "tsConfigPath": "apps/clickhouse-writer/tsconfig.app.json"
      }
    },
    "api": {
      "type": "application",
      "root": "apps/api",
      "entryFile": "main",
      "sourceRoot": "apps/api/src",
      "compilerOptions": {
        "tsConfigPath": "apps/api/tsconfig.app.json"
      }
    },
    "common": {
      "type": "library",
      "root": "libs/common",
      "entryFile": "index",
      "sourceRoot": "libs/common/src",
      "compilerOptions": {
        "tsConfigPath": "libs/common/tsconfig.lib.json"
      }
    },
    "solana-parsers": {
      "type": "library",
      "root": "libs/solana-parsers",
      "entryFile": "index",
      "sourceRoot": "libs/solana-parsers/src",
      "compilerOptions": {
        "tsConfigPath": "libs/solana-parsers/tsconfig.lib.json"
      }
    },
    "clickhouse-client": {
      "type": "library",
      "root": "libs/clickhouse-client",
      "entryFile": "index",
      "sourceRoot": "libs/clickhouse-client/src",
      "compilerOptions": {
        "tsConfigPath": "libs/clickhouse-client/tsconfig.lib.json"
      }
    },
    "kafka-client": {
      "type": "library",
      "root": "libs/kafka-client",
      "entryFile": "index",
      "sourceRoot": "libs/kafka-client/src",
      "compilerOptions": {
        "tsConfigPath": "libs/kafka-client/tsconfig.lib.json"
      }
    }
  }
}
